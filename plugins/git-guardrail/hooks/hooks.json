{
  "description": "Git 원격 작업 가드레일 — force push, 보호 브랜치 push, 위험한 gh CLI 명령을 차단합니다",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env bash ${CLAUDE_PLUGIN_ROOT}/hooks/github-guardrail.sh",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
