{
  "description": "Git 안전장치 — 위험한 원격 작업 차단",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env bash ${CLAUDE_PLUGIN_ROOT}/hooks/github-guardrail.sh",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
